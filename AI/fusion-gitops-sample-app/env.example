# OpenShift Cluster Configuration
OCP_SERVER=<OCP_SERVER>
OCP_TOKEN=<OCP_TOKEN>

# CAS Configuration
CAS_ENDPOINT=<CAS_ENDPOINT>
CAS_API_KEY=<CAS_API_KEY>
CAS_VECTOR_STORE_ID=<CAS_VECTOR_STORE_ID>  # Vector store ID (required for REST API)
CAS_USE_MCP=false  # Use MCP protocol (true) or REST API (false) - REST is actual format

# Model Gateway Configuration
MODEL_GATEWAY_ENDPOINT=<MODEL_GATEWAY_ENDPOINT>
MODEL_GATEWAY_API_KEY=<MODEL_GATEWAY_API_KEY>  # Bearer token for authentication
MODEL_NAME=<MODEL_NAME>  # Model name to use (granite, mistral, etc.)

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

# GitOps
GITOPS_REPO_URL=<GITOPS_REPO_URL>
GITOPS_BRANCH=main
