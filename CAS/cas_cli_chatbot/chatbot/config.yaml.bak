oc_username: cluster-admin
oc_password: mck9G-Aim6d-myFaR-tKd54
token_refresh_threshold: 300
cas_url: "https://console-openshift-console.apps.aws-cas-dev8.0wet.p1.openshiftapps.com/\e\
  [D\e[D\e[D\e[D\e[D\e[D\e[D\e[D\e[D\e[D\e[D\e[D"
cas_namespace: lisa-cas
cas_token: <your-cas-api-token>
default_vector_store: <default-vector-store-name>
default_limit: 5
enable_source: false
enable_content_metadata: false
llm_provider_sequence:
- nvidia
- openai
- ollama
openai_api_key: ${OPENAI_API_KEY:}
openai_model: gpt-3.5-turbo
nvidia_llm_url: <nvidia-endpoint>
nvidia_model: meta/llama3-8b-instruct
ngc_api_key: <your-ngc-api-key>
ollama_host: <ollama-host-url>
ollama_model: llama3
llm_timeout: 60
llm_max_retries: 2
logging:
  level: INFO
  file: logs/cas_chatbot.log
  max_bytes: 10485760
  backup_count: 5
  console_output: false
  structured: false
cache:
  default_ttl: 300
  max_entries: 1000
  user_cache_ttl: 600
  domain_cache_ttl: 300
session:
  file: session_history.json
  auto_save: true
  backup_enabled: true
  max_history_entries: 1000
metrics:
  enabled: true
  max_samples: 100
allow_self_signed: true
ca_cert_path: ''
force_auth_flow: auto
request_timeout: 30
subprocess_timeout: 30
rate_limit:
  enabled: false
  max_requests: 100
  time_window: 60
features:
  health_checks: true
  metrics_tracking: true
  cache_enabled: true
  auto_token_refresh: true
  session_persistence: true
cli:
  prompt_style: default
  show_welcome_banner: true
  enable_autocomplete: true
  history_size: 1000
