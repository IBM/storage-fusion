#!/usr/bin/env bash

# GUARD CLAUSE: Prevent sourcing this file multiple times
if [[ -n "${LOADED_CONFIG_ENV:-}" ]]; then
    return 0
fi
export LOADED_CONFIG_ENV=1
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load environment variables from .env file, if any, from
# the directory where the script was invoked.

# shellcheck source=lib/constants.sh
source "$SCRIPT_DIR/../lib/constants.sh"

# shellcheck source=.env
[[ -f .env ]] && source .env

#========================================
# OCP Parameters
#========================================
QUORUM_NODE_SELECTOR_LABEL="${QUORUM_NODE_SELECTOR_LABEL:-$CONTROL_ROLE}"
KUBELET_ROOT_DIR_PATH="${KUBELET_ROOT_DIR_PATH:-/var/lib/kubelet}"

#========================================
# Fusion Parameters
#========================================

FUSION_CATALOG_NAME="${FUSION_CATALOG_NAME:-"isf-operator-catalog"}"
FUSION_VERSION="${FUSION_VERSION:-2.12.0}"
CAS_VERSION="${CAS_VERSION:-v1.1}"

# Namespace where Fusion operator will be installed
FUSION_NAMESPACE="${FUSION_NAMESPACE:-ibm-spectrum-fusion-ns}"

# Install strategy: Automatic or Manual
# Automatic - operator upgrades are automatically approved
# Manual - operator upgrades require manual approval
INSTALL_STRATEGY="${INSTALL_STRATEGY:-Automatic}"

#========================================
# ODF Parameters
#========================================

# The match expressions used to identify which nodes will have storage devices
# for local disk provisioning.
# Examples:
#   "Exists:node-role.kubernetes.io/worker"
#   "In:region=us-east,us-west"
#   "Exists:node-role.kubernetes.io/worker;NotIn:beta.kubernetes.io/instance-type=gx3d.160x1792.8h100"

STORAGE_NODE_MATCH="${STORAGE_NODE_MATCH:-${WORKER_MATCH}}"

# Project name to mount RBD volumes as local disks
LOCAL_STORAGE_PROJECT="${LOCAL_STORAGE_PROJECT:-local-disk-as-pv}"
OCS_NAMESPACE="${OCS_NAMESPACE:-openshift-storage}"
LOCAL_DISK_PVC_STORAGE_CLASS="${LOCAL_DISK_PVC_STORAGE_CLASS:-${LOCAL_DISK_PVC_STORAGE_CLASS_SOURCE}-aof}"
ODF_ALLOW_ROTATIONAL="${ODF_ALLOW_ROTATIONAL:-false}"

#========================================
# Spectrum Scale Parameters
#========================================
SCALE_NAMESPACE="${SCALE_NAMESPACE:-ibm-spectrum-scale}"
SCALE_CSI_NAMESPACE="${SCALE_CSI_NAMESPACE:-${SCALE_NAMESPACE}-csi}"
SCALE_OPERATOR_NAMESPACE="${SCALE_OPERATOR_NAMESPACE:-${SCALE_NAMESPACE}-operator}"

SCALE_CLUSTER_NAME="${SCALE_CLUSTER_NAME:-}"
SCALE_CLUSTER_USE_KMM="${SCALE_CLUSTER_USE_KMM:-false}"

SCALE_DAEMON_NODE_SELECTOR_LABEL="${SCALE_DAEMON_NODE_SELECTOR_LABEL:-$FUSION_NODE_LABEL}"
SCALE_DAEMON_NODE_SELECTOR_VALUE="${SCALE_DAEMON_NODE_SELECTOR_VALUE:-}"

FILESYSTEM_NAME="${FILESYSTEM_NAME:-$DEFAULT_FS_NAME}"
FILESYSTEM_CAPACITY="${FILESYSTEM_CAPACITY:-$DEFAULT_FS_SIZE}"

#========================================
# CAS (Content Aware Storage) Configuration
#========================================
CAS_NAMESPACE="${CAS_NAMESPACE:-ibm-cas}"
CAS_SERVICE_NAME="${CAS_SERVICE_NAME:-ibm-cas-service-instance}"
CAS_STORAGE_CLASS="${CAS_STORAGE_CLASS:-ocs-storagecluster-cephfs}"
CAS_RHAI_USE_CPU="${CAS_RHAI_USE_CPU:-false}"
CAS_INSTALL_TIMEOUT="${CAS_INSTALL_TIMEOUT:-300}"
CAS_SERVICE_TIMEOUT="${CAS_SERVICE_TIMEOUT:-}"
CAS_CLEANUP_SCRIPT_URL="${CAS_CLEANUP_SCRIPT_URL:-https://raw.githubusercontent.com/IBM/storage-fusion/refs/heads/master/CAS/cas-cleanup/customer_cas_cleanup.sh}"
